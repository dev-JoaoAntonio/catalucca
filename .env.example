# ====================================================================
# Asaas — gateway de pagamento para os planos HaaS
# Solicite em https://www.asaas.com/conta/api → seção "Integrações".
# ====================================================================
# Sandbox: https://sandbox.asaas.com/api/v3
# Production: https://api.asaas.com/v3
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=

# Token validador opcional do webhook. Configure o mesmo valor no painel
# Asaas em "Configurações de webhook → Token de autenticação". Se vazio,
# a rota /api/webhook não exige header.
ASAAS_WEBHOOK_TOKEN=

# ====================================================================
# Resend — notificação por e-mail dos eventos Asaas (PAYMENT_RECEIVED etc.)
# https://resend.com — opcional. Se vazio, o webhook só registra logs.
# ====================================================================
RESEND_API_KEY=
NOTIFY_EMAIL=contato@catalucca.com.br
NOTIFY_FROM=no-reply@catalucca.com.br
